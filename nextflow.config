manifest {
    name = "nxf-savont"
    author = "angelovangel"
    homePage = "https://github.com/angelovangel/nxf-savont"
    defaultBranch = "main"
    description = "Nextflow pipeline for taxonomic profiling for full-length 16S reads (ONT, PacBio)"
    version = "0.1.0"
    nextflowVersion = ">=23.04"
    
}

params {
    pod5 = null
    model = "hac"
    reads = null
    filter = null
    subsample = null
    samplesheet = null
    kit = null
    samplename = null
    db = "emu" // "emu" or "silva"
    outdir = "output"
    cpus = 16
}

profiles {
    standard {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g) --platform linux/amd64'
        process.cpus = params.cpus
    }

    dev {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process {
            cpus = 4
            withName: 'DORADO_BASECALL|DORADO_BASECALL_BARCODING' {
                container = null
            } 
        }
    }
}